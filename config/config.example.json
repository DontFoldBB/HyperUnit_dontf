{
  // ════════════════════════════════════════════════════════════════════
  //  ОБРАЗЕЦ. Скопируй в config.json и меняй значения прямо здесь.
  //  Где что лежит (3 файла рядом с main.py):
  //    • config.json   — ЭТИ параметры (что и как делать)
  //    • .env          — ключи Bitget: BITGET_API_KEY/SECRET/PASSPHRASE (+ опц. ETH_RPC_URL)
  //    • wallets.xlsx  — кошельки: столбец A = приватник, столбец B = адрес депозита Bitget
  //  ⚠ Запуск ВСЕГДА реальный. Прогон идёт по ВСЕМ кошелькам из wallets.xlsx (1 строка = 1 аккаунт).
  //  Комментарии // и # разрешены.
  // ════════════════════════════════════════════════════════════════════

  // Какие модули включены (галочки можно ставить и в меню):
  "modules": {
    "bitget":        true,   // [1] вывод ETH с Bitget на кошелёк
    "deposit":       true,   // [2] депозит на Hyperliquid через Unit
    "trade":         true,   // [3] торговля / набивка объёма
    "withdraw":      true,   // [4] вывод с Hyperliquid обратно в Ethereum
    "bitget_return": true    // [5] возврат ETH с кошелька на Bitget (адрес — из wallets.xlsx)
  },

  // Порядок прохода по кошелькам из wallets.xlsx (можно переключить и в меню):
  "randomize_wallets": false,   // false = по порядку строк; true = перемешать на каждом запуске

  // Пропускать аккаунты, где прошли все ВКЛЮЧЁННЫЕ стадии (пишутся в output/done_accounts.txt) — резюме после обрыва.
  // Если хоть одна включённая стадия упала → output/failed_accounts.txt и повтор на следующем запуске. Удали done_accounts.txt, чтобы прогнать всех заново.
  "skip_done_accounts": true,    // true = пропускать успешно сделанные

  // Лимитные ордера для перпов и HIP-3 (дешевле маркета: меньше слиппеджа/комиссий). Спот ВСЕГДА лимиткой, независимо.
  // Механика: лимитка по миду, ждёт ~10с, не исполнилась — переставляет на текущую цену; последняя попытка чуть крестит спред.
  // Закрытие позиции при неполном исполнении добивается market_close (позиция никогда не остаётся открытой). Тумблер есть и в меню (l).
  "limit_orders": false,         // false = маркет (как было); true = лимитки на перпах/HIP-3

  // «Продолжить»: перед торговлей подобрать хвосты упавшего прогона — закрыть оставшиеся позиции
  // (perp+HIP-3) и смести застрявший USDC с perp/DEX обратно на спот. Идемпотентно. Тумблер есть и в меню (c).
  "recover_tails": false,        // true = перед кругом подбирать хвосты прошлого прогона

  // Прокси на КАЖДЫЙ аккаунт — в wallets.xlsx, столбец C. Форматы: http://user:pass@host:port | host:port:user:pass | host:port.
  // Весь трафик аккаунта (Unit/Hyperliquid/RPC) идёт через его прокси; Bitget по умолчанию НЕ через прокси (его API на IP-whitelist).
  "proxy_bitget": false,         // true = пускать и Bitget через прокси аккаунта (тогда добавь IP прокси в whitelist Bitget либо отключи whitelist)

  // Выключать DEX abstraction перед торговлей (стандартный режим маржи). По умолчанию false — режим аккаунта НЕ трогаем (unified; HIP-3 фондится через перп-баланс + cross).
  // true — ТОЛЬКО если переводы USDC падают 'Cannot transfer with DEX abstraction enabled': бот сам выключит abstraction и будет фондить HIP-3 напрямую (spot→DEX, isolated).
  "disable_dex_abstraction": false,

  // Builder-комиссия Hyperliquid: маленький % с каждого ордера. Адрес и ставка вшиты в код — здесь только вкл/выкл.
  "builder_codes": true,         // true = включить builder-комиссию

  // [1] Сколько выводить с Bitget на каждый кошелёк:
  "bitget_amount_eth": "80-100%",   // СО знаком % = доля баланса ("80-100%", "50%"); БЕЗ % = кол-во ETH ("0.01", "0.01-0.03"); ещё "all"

  // [2] Сколько % ETH с кошелька задепнуть на Hyperliquid:
  "deposit_percent": "90-95",   // процент (без знака %): число 90 или вилка "90-95" / [90,95] — случайно на кошелёк

  // [3] Торговля — ЧТО крутить:
  "trade_hip3":         ["NVDA", "TSLA", "AAPL", "MSFT", "GOLD", "SP500"],  // HIP-3 активы; [] = без них.  Ликвидные: CL, XYZ100, BRENTOIL, SP500, MU, SILVER, NVDA, SNDK, INTC, ARM
  "trade_perp":         "pair",  // "none" | "pair" (BTC+ETH вместе) | "single".  Ликвидные перпы (для "single"): BTC, HYPE, ETH, ZEC, SOL, NEAR, TON, BNB, WLD, XRP
  "trade_single_coin":  ["BTC", "ETH", "SOL", "BNB", "XRP", "HYPE", "NEAR"],  // пул для "single": крутит перпы по одному СЛУЧАЙНО до target_perp (как HIP-3). Можно один тикер: "SOL"

  //     СКОЛЬКО объёма набить ($), 0 = один проход.  Число или вилка "800-1200" / [800,1200] (случайно на кошелёк):
  "trade_target_hip3":  "800-1200",   // целевой объём $ в HIP-3
  "trade_target_perp":  "800-1200",   // целевой объём $ в перпах

  //     КАК крутить:
  "trade_margin_pct":   "50-95",   // маржа на позицию (процент от проданного эфира). Число 80 или вилка "50-95" / [50,95], без знака %
  "trade_leverage":     "5-7",       // плечо для перпов. Число (5) или вилка "3-5" / [3,5] — округлится до целого
  "trade_hold_minutes": [0.5, 2],  // держать позицию, минут. число = фикс., [мин,макс] = случайно на каждой
  "trade_gap_minutes":  [0.2, 1],  // пауза между сделками, минут. [мин,макс] = случайно на каждой

  // [4] Сколько выводить с Hyperliquid обратно:
  "withdraw_amount": "all",      // "all" = всё | "0.05" = столько ETH | "50%" | "50-70%"

  // [5] Сколько % ETH вернуть на Bitget (адрес — из wallets.xlsx, столбец B):
  "bitget_return_percent": 100,  // процент (без %): 100 = весь баланс минус газ. Можно вилку "95-100" / [95,100]

  // ════════════════════════════════════════════════════════════════════
  //  ДОПОЛНИТЕЛЬНО — обычно не трогаешь.
  // ════════════════════════════════════════════════════════════════════
  "advanced": {
    "module_gap_sec": [15, 30],         // пауза между шагами/кошельками, сек (как человек). [мин,макс] или число; 0 = без
    "bitget_wait_arrival": true,        // ждать прихода ETH на кошелёк после вывода с Bitget
    "bitget_wait_timeout_sec": 900,     // макс. ожидание прихода с Bitget, сек
    "bitget_withdraw_unlock_wait_min": 30, // вывод с Bitget: ждать разморозки свежего депозита для вывода, мин (деньги с прошлого кошелька зачислились, но залочены) — авто-повтор при code 13008
    "deposit_wait_credit": true,        // ждать зачисления UETH на Hyperliquid
    "deposit_wait_timeout_min": 0,      // 0 = ждать без лимита, пока не придёт
    "trade_reserve_usdc": 1.0,          // оставить USDC на споте (~1 нужен для вывода через Unit)
    "trade_size_jitter": 0.35,          // разброс размера позиций (0.35 = 65..100% маржи; 0 = одинаковые)
    "withdraw_wait": true,              // ждать зачисления ETH на Ethereum
    "withdraw_wait_timeout_min": 30,    // таймаут ожидания вывода, мин (0 = без таймаута)
    "withdraw_poll_sec": 20,            // период проверки статуса вывода, сек
    "bitget_return_wait": true,         // ждать квитанцию Ethereum по возврату на Bitget
    "bitget_return_wait_credit": true   // ждать зачисления на Bitget (мейн/субакк) и свести субакк→мейн
  }
}
