# ПРИМЕР. Скопируй этот файл в .env (в этой же папке config/) и впиши свои значения.
# Файл .env в git НЕ отслеживается (см. .gitignore) — твои ключи останутся только локально.

# Ключи Bitget (нужны права Spot + Withdraw + IP-whitelist). Один аккаунт на все кошельки.
BITGET_API_KEY=
BITGET_API_SECRET=
BITGET_API_PASSPHRASE=

# Необязательно: свой RPC Ethereum (пусто = публичные ноды).
ETH_RPC_URL=
