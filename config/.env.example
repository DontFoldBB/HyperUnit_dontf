# Скопируй этот файл в config/.env и впиши свои значения.
# Один аккаунт Bitget на ВСЕ кошельки. Нужны права: Spot + Withdraw + IP-whitelist.

BITGET_API_KEY=
BITGET_API_SECRET=
BITGET_API_PASSPHRASE=

# Необязательно: свой RPC Ethereum (Alchemy/Infura/свой нод). Пусто = публичные RPC.
ETH_RPC_URL=
