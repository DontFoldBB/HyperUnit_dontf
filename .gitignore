# ============================================================
#  Реальные настройки лежат локально и НЕ отслеживаются git.
#  Возьми примеры рядом и скопируй БЕЗ ".example":
#    config/.env.example          ->  config/.env
#    config/config.example.json   ->  config/config.json
#    config/wallets.example.xlsx  ->  config/wallets.xlsx
#  Затем впиши свои значения — они останутся только у тебя.
# ============================================================
config/.env
config/config.json
config/wallets.xlsx

# Локи/бэкапы/мусор рядом с конфигом:
config/.~lock.*#
config/~$*
config/*.bak

# Отчёты прогонов (адреса, суммы)
output/*
!output/.gitkeep

# Журналы/кэши вендоренных модулей (пишутся в lib/ при работе)
lib/*.csv
lib/*.log
lib/.min_cache.json
deposits_log.csv
withdrawals*.csv

# Ключи/сертификаты (на всякий случай)
*.key
*.pem

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# Логи / временное / мусор ОС
*.log
*.tmp
.~lock.*#
~$*
системный
