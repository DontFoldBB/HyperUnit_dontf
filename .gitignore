# ============================================================
#  В репозитории лежат ПУСТЫЕ заготовки config/.env, config.json,
#  wallets.xlsx — их можно заполнять прямо на месте. Твои заполненные
#  значения НЕ попадают в git (на .env и wallets.xlsx стоит skip-worktree).
#  Не отслеживаем только локи/бэкапы/мусор:
# ============================================================
config/.~lock.*#
config/~$*
config/*.bak

# Отчёты прогонов (адреса, суммы)
output/*
!output/.gitkeep

# Журналы/кэши вендоренных модулей (пишутся в lib/ при работе)
lib/*.csv
lib/*.log
lib/.min_cache.json
deposits_log.csv
withdrawals*.csv

# Ключи/сертификаты (на всякий случай)
*.key
*.pem

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# Логи / временное / мусор ОС
*.log
*.tmp
.~lock.*#
~$*
системный
